[Unit]
Description=W-Edu Backend (FastAPI)
After=network.target postgresql.service
Requires=postgresql.service

[Service]
Type=simple
User=www-data
WorkingDirectory=/var/www/W-Edu/backend
EnvironmentFile=/var/www/W-Edu/backend/.env
Environment=PYTHONPATH=/var/www/W-Edu/backend
ExecStart=/var/www/W-Edu/backend/.venv/bin/uvicorn main:app --host 0.0.0.0 --port 8000 --workers 2
Restart=always
RestartSec=5

[Install]
WantedBy=multi-user.target
