[Unit]
Description=W-Edu Frontend (Next.js)
After=network.target wedu-backend.service

[Service]
Type=simple
User=www-data
WorkingDirectory=/var/www/W-Edu/W-Edu/frontend
ExecStart=/usr/bin/npm start
Restart=always
RestartSec=5
Environment=PORT=3000
Environment=NODE_ENV=production

[Install]
WantedBy=multi-user.target
